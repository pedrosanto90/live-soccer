# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# New-style publishable key (sb_publishable_...) — used by the browser/server clients
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# New-style secret key (sb_secret_...) — server-only, never expose to the browser
SUPABASE_SECRET_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Credenciais do utilizador usado pelos testes E2E (Cypress) — ver
# scripts/create-test-user.mjs e `npm run test:create-user`.
CYPRESS_TEST_USER_EMAIL=test@futsal-manager.dev
CYPRESS_TEST_USER_PASSWORD=testpassword123

# Sentry — monitorização de erros e tracing
# DSN público (cliente/browser) e privado (servidor/edge)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Upload de source maps no `next build` (server-only)
SENTRY_ORG=
SENTRY_PROJECT=

